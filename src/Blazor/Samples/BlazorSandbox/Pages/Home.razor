@page "/"
@inject NavigationManager Navigation

<PageTitle>Home</PageTitle>

<h1>Redirecting</h1>

<p>Opening the SKMesh probe.</p>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Navigation.NavigateTo("/skmesh-probe", replace: true);
        }
    }
}
