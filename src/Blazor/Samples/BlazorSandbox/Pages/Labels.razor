@page "/labels"
@using DrawnUi
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaLabel</PageTitle>

<div class="docs-page">
    <h1>SkiaLabel</h1>
    <p class="docs-lead">SkiaLabel is the baseline text control in DrawnUI. Use it for titles, status text, captions, and any text block that does not need markdown parsing.</p>
    <p class="docs-note">This example keeps the page small on purpose: one headline, one centered caption, and one wrapped note card. That is enough to show the core text API.</p>

    <div class="docs-example-frame">
        <Canvas WidthRequest="360"
                HeightRequest="296"
                BackgroundColor="#F6F1E8"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                RootControl="@RootControl" />
    </div>

    <pre class="docs-code"><code>@LabelSnippet</code></pre>
</div>

@code {
    private const string LabelSnippet = """
var title = new SkiaLabel()
{
    Text = "SkiaLabel",
    FontSize = 26,
    FontFamily = "FontTextTitle",
    TextColor = Colors.Black
};
""";

    private readonly SkiaControl RootControl;

    public Labels()
    {
        RootControl = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 328,
            HeightRequest = 264,
            Padding = new Thickness(18),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Type = LayoutType.Column,
            Spacing = 12,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaLabel",
                    FontFamily = "FontTextTitle",
                    FontSize = 26,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                new SkiaLabel()
                {
                    Text = "Simple text, alignment, and wrapping stay inside the same Skia rendering tree.",
                    FontFamily = "FontText",
                    FontSize = 14,
                    TextColor = new Color(0.365f, 0.314f, 0.231f, 1f),
                    HorizontalOptions = LayoutOptions.Fill,
                    HorizontalTextAlignment = DrawTextAlignment.Center
                },
                new SkiaShape()
                {
                    WidthRequest = 292,
                    HeightRequest = 84,
                    Type = ShapeType.Rectangle,
                    CornerRadius = 18,
                    BackgroundColor = Colors.White,
                    StrokeColor = new Color(0.851f, 0.827f, 0.776f, 1f),
                    StrokeWidth = 1,
                    HorizontalOptions = LayoutOptions.Center,
                    Children =
                    {
                        new SkiaLabel()
                        {
                            WidthRequest = 244,
                            Text = "Use SkiaLabel when you want lightweight drawn text without markdown parsing or span generation.",
                            FontFamily = "FontText",
                            FontSize = 15,
                            MaxLines = 3,
                            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
                            HorizontalOptions = LayoutOptions.Center,
                            VerticalOptions = LayoutOptions.Center,
                            HorizontalTextAlignment = DrawTextAlignment.Center
                        }
                    }
                },
                new SkiaLabel()
                {
                    Text = "Status labels, helper text, card titles, and overlay captions are the common use cases.",
                    FontFamily = "FontText",
                    FontSize = 13,
                    TextColor = new Color(0.424f, 0.361f, 0.275f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                }
            }
        };
    }
}