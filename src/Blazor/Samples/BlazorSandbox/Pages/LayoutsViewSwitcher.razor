@page "/layouts-view-switcher"
@using DrawnUi
@using DrawnUi.Controls
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaViewSwitcher</PageTitle>

<div class="docs-page">
    <h1>SkiaViewSwitcher</h1>
    <p class="docs-lead">SkiaViewSwitcher shows one child view at a time and is a good fit for step flows, state pages, and shell-sized surface swaps where everything should remain drawn.</p>
    <p class="docs-note">Use the buttons to switch the active card. The example intentionally stays small and focuses on the selected view behavior.</p>

    <div class="docs-example-frame">
        <Canvas WidthRequest="360"
                HeightRequest="364"
                BackgroundColor="#F6F0E6"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                RootControl="@RootControl" />
    </div>

    <pre class="docs-code"><code>@ViewSwitcherSnippet</code></pre>
</div>

@code {
    private const string ViewSwitcherSnippet = """
var switcher = new SkiaViewSwitcher()
{
    SelectedIndex = 0,
    Children = { firstView, secondView, thirdView }
};
""";

    private readonly SkiaViewSwitcher _switcher;
    private readonly SkiaLabel _statusLabel;
    private readonly SkiaControl RootControl;

    public LayoutsViewSwitcher()
    {
        _statusLabel = new SkiaLabel()
        {
            Text = "Active view: Overview",
            FontFamily = "FontText",
            FontSize = 13,
            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
            HorizontalOptions = LayoutOptions.Fill,
            HorizontalTextAlignment = DrawTextAlignment.Center
        };

        _switcher = new SkiaViewSwitcher()
        {
            WidthRequest = 292,
            HeightRequest = 170,
            SelectedIndex = 0,
            HorizontalOptions = LayoutOptions.Center,
            Children =
            {
                CreateSwitcherCard("Overview", new Color(0.918f, 0.941f, 0.976f, 1f)),
                CreateSwitcherCard("Inspect", new Color(0.961f, 0.925f, 0.898f, 1f)),
                CreateSwitcherCard("Publish", new Color(0.922f, 0.961f, 0.929f, 1f))
            }
        };

        RootControl = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 328,
            HeightRequest = 332,
            Padding = new Thickness(18),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Type = LayoutType.Column,
            Spacing = 12,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaViewSwitcher",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                _switcher,
                new SkiaLayout()
                {
                    WidthRequest = 292,
                    Type = LayoutType.Row,
                    Spacing = 10,
                    HorizontalOptions = LayoutOptions.Center,
                    Children =
                    {
                        CreateSwitcherButton("Overview", 0),
                        CreateSwitcherButton("Inspect", 1),
                        CreateSwitcherButton("Publish", 2)
                    }
                },
                _statusLabel
            }
        };
    }

    private SkiaButton CreateSwitcherButton(string text, int index)
    {
        var button = new SkiaButton(text)
        {
            WidthRequest = 88,
            HeightRequest = 34,
            BackgroundColor = new Color(0.157f, 0.278f, 0.420f, 1f),
            TextColor = Colors.White,
            CornerRadius = 10,
            HorizontalOptions = LayoutOptions.Center
        };

        button.Tapped += (_, _) =>
        {
            _switcher.SelectedIndex = index;
            _statusLabel.Text = $"Active view: {text}";
            _ = InvokeAsync(StateHasChanged);
        };

        return button;
    }

    private static SkiaShape CreateSwitcherCard(string title, Color color)
    {
        return new SkiaShape()
        {
            WidthRequest = 292,
            HeightRequest = 170,
            Type = ShapeType.Rectangle,
            CornerRadius = 20,
            BackgroundColor = color,
            Children =
            {
                new SkiaLayout()
                {
                    Padding = new Thickness(18),
                    Type = LayoutType.Column,
                    Spacing = 6,
                    Children =
                    {
                        new SkiaLabel()
                        {
                            Text = title,
                            FontFamily = "FontTextTitle",
                            FontSize = 22,
                            TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                            HorizontalOptions = LayoutOptions.Fill
                        },
                        new SkiaLabel()
                        {
                            Text = "Only one child is visible at a time, which makes this a clean fit for discrete page states.",
                            FontFamily = "FontText",
                            FontSize = 14,
                            TextColor = new Color(0.365f, 0.314f, 0.231f, 1f),
                            HorizontalOptions = LayoutOptions.Fill,
                            WidthRequest = 220
                        }
                    }
                }
            }
        };
    }
}