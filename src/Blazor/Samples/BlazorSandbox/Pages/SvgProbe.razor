@page "/svg-probe"
@using DrawnUi.Draw
@using DrawnUi.Views

@using DrawnUi

<PageTitle>Svg Probe</PageTitle>

<h1>Svg Probe</h1>

<p id="svg-probe-description">Use this page to validate the shared SkiaSvg browser port.</p>
<p id="svg-local-status">@_localSvgStatus</p>
<p id="svg-remote-status">@_remoteSvgStatus</p>

<Canvas WidthRequest="420"
        HeightRequest="760"
        BackgroundColor="#FAF7F0"
        Margin="0,16,0,32"
        RootControl="@_rootControl" />

@code {
    private readonly SkiaControl _rootControl;
    private string _localSvgStatus = "svg local: pending";
    private string _remoteSvgStatus = "svg remote: pending";

    public SvgProbe()
    {
        var localSvg = CreateProbeSvg(
            "local",
            "media/dotnet_bot.svg",
            new Color(0.129f, 0.451f, 0.847f, 1f),
            Colors.Transparent);

        var remoteSvg = CreateProbeSvg(
            "remote",
            "https://cdn.jsdelivr.net/gh/simple-icons/simple-icons/icons/dotnet.svg",
            Colors.Transparent,
            Colors.Transparent);

        _rootControl = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 388,
            HeightRequest = 720,
            Padding = new Thickness(20),
            BackgroundColor = new Color(0.992f, 0.973f, 0.933f, 1f),
            Type = LayoutType.Column,
            Spacing = 16,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaSvg shared probe",
                    FontFamily = "FontTextTitle",
                    FontSize = 28,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                new SkiaLabel()
                {
                    Text = "Expected: one local svg and one remote svg rendered below.",
                    FontFamily = "FontText",
                    FontSize = 15,
                    TextColor = new Color(0.365f, 0.314f, 0.231f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                CreateCard("Local svg from wwwroot/media", localSvg),
                CreateCard("Remote svg from jsDelivr", remoteSvg)
            }
        };
    }

    private SkiaSvg CreateProbeSvg(string key, string source, Color tintColor, Color shadowColor)
    {
        var svg = new SkiaSvg()
        {
            WidthRequest = 220,
            HeightRequest = 140,
            HorizontalOptions = LayoutOptions.Center,
            VerticalOptions = LayoutOptions.Center,
            Aspect = TransformAspect.AspectFit,
            TintColor = tintColor,
            ShadowColor = shadowColor,
            Source = source
        };

        svg.Success += (_, value) => SetSvgStatus(key, $"svg {key}: loaded {value}");
        svg.Error += (_, exception) => SetSvgStatus(key, $"svg {key}: error {exception.Message}");

        return svg;
    }

    private void SetSvgStatus(string key, string value)
    {
        if (key == "local")
        {
            _localSvgStatus = value;
        }
        else
        {
            _remoteSvgStatus = value;
        }

        Console.WriteLine($"[SvgProbe] {value}");
        _ = InvokeAsync(StateHasChanged);
    }

    private static SkiaShape CreateCard(string title, SkiaSvg svg)
    {
        return new SkiaShape()
        {
            WidthRequest = 348,
            HeightRequest = 220,
            Type = ShapeType.Rectangle,
            CornerRadius = 20,
            BackgroundColor = Colors.White,
            StrokeColor = new Color(0.769f, 0.706f, 0.588f, 1f),
            StrokeWidth = 1,
            Padding = new Thickness(18),
            Children =
            {
                new SkiaLayout()
                {
                    Type = LayoutType.Column,
                    Spacing = 12,
                    VerticalOptions = LayoutOptions.Fill,
                    Children =
                    {
                        new SkiaLabel()
                        {
                            Text = title,
                            FontFamily = "FontTextTitle",
                            FontSize = 18,
                            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
                            HorizontalOptions = LayoutOptions.Fill
                        },
                        svg
                    }
                }
            }
        };
    }
}