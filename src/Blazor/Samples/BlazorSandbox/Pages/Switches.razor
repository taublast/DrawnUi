@page "/switches"
@using DrawnUi
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaSwitch</PageTitle>

<div class="docs-page">
    <h1>SkiaSwitch</h1>
    <p class="docs-lead">DrawnUI ships toggle-style controls that stay inside the same Skia tree as the rest of your UI. This keeps switches, checkboxes, and their visuals consistent across platforms.</p>
    <p class="docs-note">Tap the controls in the canvas. The summary line shows the current state without leaving the compact example format.</p>

    <div class="docs-example-frame">
        <Canvas WidthRequest="360"
                HeightRequest="296"
                BackgroundColor="#F5F0E5"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                RootControl="@RootControl" />
    </div>

    <pre class="docs-code"><code>@SwitchSnippet</code></pre>
</div>

@code {
    private const string SwitchSnippet = """
var newsletter = new SkiaSwitch()
{
    DefaultValue = true,
    ColorFrameOn = Colors.SeaGreen
};

newsletter.Toggled += (_, isOn) => { /* react here */ };
""";

    private readonly SkiaLabel _summaryLabel;
    private readonly SkiaSwitch _notificationsSwitch;
    private readonly SkiaSwitch _updatesSwitch;
    private readonly SkiaCheckbox _termsCheckbox;
    private readonly SkiaControl RootControl;

    public Switches()
    {
        _summaryLabel = new SkiaLabel()
        {
            Text = "Notifications on, updates off, terms accepted.",
            FontFamily = "FontText",
            FontSize = 13,
            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
            HorizontalOptions = LayoutOptions.Fill
        };

        _notificationsSwitch = new SkiaSwitch()
        {
            WidthRequest = 54,
            HeightRequest = 32,
            DefaultValue = true,
            ColorFrameOn = new Color(0.176f, 0.616f, 0.353f, 1f),
            ColorFrameOff = new Color(0.788f, 0.808f, 0.843f, 1f),
            HorizontalOptions = LayoutOptions.End
        };

        _updatesSwitch = new SkiaSwitch()
        {
            WidthRequest = 54,
            HeightRequest = 32,
            ControlStyle = PrebuiltControlStyle.Material,
            ColorFrameOn = new Color(0.129f, 0.588f, 0.953f, 1f),
            HorizontalOptions = LayoutOptions.End
        };

        _termsCheckbox = new SkiaCheckbox()
        {
            WidthRequest = 24,
            HeightRequest = 24,
            ControlStyle = PrebuiltControlStyle.Cupertino,
            DefaultValue = true,
            HorizontalOptions = LayoutOptions.End
        };

        _notificationsSwitch.Toggled += OnToggleChanged;
        _updatesSwitch.Toggled += OnToggleChanged;
        _termsCheckbox.Toggled += OnToggleChanged;

        RootControl = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 328,
            HeightRequest = 264,
            Padding = new Thickness(18),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Type = LayoutType.Column,
            Spacing = 12,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "Toggle controls",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                CreateRow("Notifications", "Default switch styling", _notificationsSwitch),
                CreateRow("Product updates", "Material switch styling", _updatesSwitch),
                CreateRow("Accept terms", "Checkbox variant built on the same toggle base", _termsCheckbox),
                _summaryLabel
            }
        };
    }

    private void OnToggleChanged(object? sender, bool value)
    {
        _summaryLabel.Text = $"Notifications {StateWord(_notificationsSwitch.IsToggled)}, updates {StateWord(_updatesSwitch.IsToggled)}, terms {(_termsCheckbox.IsToggled ? "accepted" : "pending")}.";
        _ = InvokeAsync(StateHasChanged);
    }

    private static string StateWord(bool value)
    {
        return value ? "on" : "off";
    }

    private static SkiaLayout CreateRow(string title, string caption, SkiaControl control)
    {
        return new SkiaLayout()
        {
            WidthRequest = 292,
            Padding = new Thickness(12, 10),
            BackgroundColor = Colors.White,
            Type = LayoutType.Row,
            Spacing = 12,
            Children =
            {
                new SkiaLayout()
                {
                    WidthRequest = 228,
                    Type = LayoutType.Column,
                    Spacing = 2,
                    Children =
                    {
                        new SkiaLabel()
                        {
                            Text = title,
                            FontFamily = "FontTextTitle",
                            FontSize = 17,
                            TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                            HorizontalOptions = LayoutOptions.Fill
                        },
                        new SkiaLabel()
                        {
                            Text = caption,
                            FontFamily = "FontText",
                            FontSize = 12,
                            TextColor = new Color(0.365f, 0.314f, 0.231f, 1f),
                            HorizontalOptions = LayoutOptions.Fill
                        }
                    }
                },
                control
            }
        };
    }
}