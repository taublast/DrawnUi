@page "/graphics-svg"
@using DrawnUi
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaSvg</PageTitle>

<div class="docs-page">
    <h1>SkiaSvg</h1>
    <p class="docs-lead">SkiaSvg renders vector assets inside the same DrawnUI composition tree. That makes it a good fit for icons, logos, and scalable illustrations that need tinting or layout control.</p>
    <p class="docs-note">This page shows a local SVG asset and a tinted variant so the most common setup is visible immediately.</p>

    <div class="docs-example-frame">
        <Canvas Content="_canvasContent" WidthRequest="380"
                HeightRequest="330"
                BackgroundColor="#FBF7F0"
                Margin="0,8,0,0"
                 />
    </div>

    <pre class="docs-code"><code>@SvgSnippet</code></pre>
</div>

@code {
    private const string SvgSnippet = """
var logo = new SkiaSvg()
{
    Source = "media/dotnet_bot.svg",
    Aspect = TransformAspect.AspectFit,
    TintColor = Colors.CornflowerBlue
};
""";

    private SkiaControl _canvasContent;

    public GraphicsSvg()
    {
        _canvasContent = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 348,
            HeightRequest = 298,
            Padding = new Thickness(18),
            BackgroundColor = new Color(0.992f, 0.973f, 0.933f, 1f),
            Type = LayoutType.Column,
            Spacing = 14,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaSvg",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                new SkiaLayout()
                {
                    Type = LayoutType.Row,
                    Spacing = 12,
                    HorizontalOptions = LayoutOptions.Center,
                    Children =
                    {
                        CreateSvgCard("Local", Colors.Transparent),
                        CreateSvgCard("Tinted", new Color(0.129f, 0.451f, 0.847f, 1f))
                    }
                }
            }
        };
    }

    private static SkiaShape CreateSvgCard(string title, Color tint)
    {
        return new SkiaShape()
        {
            WidthRequest = 146,
            HeightRequest = 190,
            Type = ShapeType.Rectangle,
            CornerRadius = 18,
            BackgroundColor = Colors.White,
            StrokeColor = new Color(0.769f, 0.706f, 0.588f, 1f),
            StrokeWidth = 1,
            Padding = new Thickness(14),
            Children =
            {
                new SkiaLayout()
                {
                    Type = LayoutType.Column,
                    Spacing = 10,
                    VerticalOptions = LayoutOptions.Fill,
                    Children =
                    {
                        new SkiaLabel()
                        {
                            Text = title,
                            FontFamily = "FontTextTitle",
                            FontSize = 16,
                            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
                            HorizontalOptions = LayoutOptions.Center
                        },
                        new SkiaSvg()
                        {
                            WidthRequest = 100,
                            HeightRequest = 100,
                            HorizontalOptions = LayoutOptions.Center,
                            VerticalOptions = LayoutOptions.Center,
                            Aspect = TransformAspect.AspectFit,
                            TintColor = tint,
                            Source = "media/dotnet_bot.svg"
                        }
                    }
                }
            }
        };
    }
}