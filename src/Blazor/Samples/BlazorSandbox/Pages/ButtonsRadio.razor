@page "/buttons-radio"
@using DrawnUi
@using DrawnUi.Controls
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>Radio Buttons</PageTitle>

<div class="docs-page">
    <h1>Radio Buttons</h1>
    <p class="docs-lead">SkiaRadioButton supports two real grouping modes: radios can group by their immediate parent container, or they can group by a shared <code>GroupName</code> even when they live in different containers.</p>
    <p class="docs-note">This demo mirrors the MAUI sandbox more closely: framed sections, wrapped options, and custom radio content instead of the bare default surface. Test both sections below.</p>

    <div class="docs-example-frame">
        <Canvas WidthRequest="360"
                HeightRequest="620"
                BackgroundColor="#F6F0E6"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                RootControl="@RootControl" />
    </div>

    <pre class="docs-code"><code>@RadioSnippet</code></pre>
</div>

@code {
    private const string RadioSnippet = """
var parentGrouped = new SkiaLayout()
{
    Type = LayoutType.Wrap,
    Children =
    {
        new SkiaRadioButton("Flowers"),
        new SkiaRadioButton("Food"),
        new SkiaRadioButton("Origami")
    }
};

var named = new SkiaRadioButton("Express") { GroupName = "delivery" };
""";

    private readonly SkiaLabel _containerSummaryLabel;
    private readonly SkiaLabel _namedSummaryLabel;
    private readonly List<SkiaRadioButton> _containerGroupRadios;
    private readonly List<SkiaRadioButton> _namedGroupRadios;
    private readonly SkiaControl RootControl;

    public ButtonsRadio()
    {
        _containerSummaryLabel = new SkiaLabel()
        {
            Text = "Container group: Flowers",
            FontFamily = "FontText",
            FontSize = 13,
            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
            HorizontalOptions = LayoutOptions.Fill
        };

        _namedSummaryLabel = new SkiaLabel()
        {
            Text = "Named group: Standard",
            FontFamily = "FontText",
            FontSize = 13,
            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
            HorizontalOptions = LayoutOptions.Fill
        };

        _containerGroupRadios =
        [
            CreateRadio("Flowers", OnContainerGroupChanged, true),
            CreateRadio("Food", OnContainerGroupChanged),
            CreateRadio("Origami", OnContainerGroupChanged),
            CreateRadio("Lego Bricks", OnContainerGroupChanged),
            CreateRadio("Something else", OnContainerGroupChanged),
            CreateRadio("Various", OnContainerGroupChanged)
        ];

        _namedGroupRadios =
        [
            CreateRadio("Standard", OnNamedGroupChanged, true, "delivery"),
            CreateRadio("Priority", OnNamedGroupChanged, false, "delivery"),
            CreateRadio("Express", OnNamedGroupChanged, false, "delivery"),
            CreateRadio("Courier", OnNamedGroupChanged, false, "delivery")
        ];

        RootControl = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 328,
            HeightRequest = 588,
            Padding = new Thickness(18),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Type = LayoutType.Column,
            Spacing = 12,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaRadioButton",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                new SkiaLabel()
                {
                    Text = "The first frame groups by shared parent container. The second frame groups by shared GroupName across two different containers.",
                    FontFamily = "FontText",
                    FontSize = 12,
                    TextColor = new Color(0.365f, 0.314f, 0.231f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                CreateContainerGroupFrame(),
                _containerSummaryLabel,
                CreateNamedGroupFrame(),
                _namedSummaryLabel
            }
        };
    }

    private SkiaLayout CreateContainerGroupFrame()
    {
        var content = new SkiaLayout()
        {
            WidthRequest = 252,
            HeightRequest = 102,
            Type = LayoutType.Wrap,
            Spacing = 12,
            HorizontalOptions = LayoutOptions.Fill,
            Children = _containerGroupRadios.Cast<SkiaControl>().ToList()
        };

        return CreateFrame("Grouped by parent container", content, 150);
    }

    private SkiaLayout CreateNamedGroupFrame()
    {
        var content = new SkiaLayout()
        {
            WidthRequest = 252,
            HeightRequest = 60,
            Type = LayoutType.Wrap,
            Spacing = 12,
            HorizontalOptions = LayoutOptions.Fill,
            Children =
            {
                CreateNamedGroupHost(_namedGroupRadios[0]),
                CreateNamedGroupHost(_namedGroupRadios[1]),
                CreateNamedGroupHost(_namedGroupRadios[2]),
                CreateNamedGroupHost(_namedGroupRadios[3])
            }
        };

        return CreateFrame("Grouped by shared GroupName", content, 112);
    }

    private static SkiaLayout CreateNamedGroupHost(SkiaRadioButton radio)
    {
        return new SkiaLayout()
        {
            WidthRequest = 112,
            HeightRequest = 24,
            Type = LayoutType.Column,
            Children =
            {
                radio
            }
        };
    }

    private static SkiaLayout CreateFrame(string title, SkiaControl content, double contentHeight)
    {
        return new SkiaLayout()
        {
            WidthRequest = 292,
            Type = LayoutType.Column,
            Spacing = 0,
            HorizontalOptions = LayoutOptions.Center,
            Children =
            {
                new SkiaLabel()
                {
                    Margin = new Thickness(16, 0, 0, 0),
                    Padding = new Thickness(4, 0),
                    BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
                    Text = title,
                    FontFamily = "FontText",
                    FontSize = 13,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f)
                },
                new SkiaShape()
                {
                    WidthRequest = 292,
                    HeightRequest = contentHeight,
                    Type = ShapeType.Rectangle,
                    CornerRadius = 12,
                    HorizontalOptions = LayoutOptions.Fill,
                    StrokeColor = Colors.Black,
                    StrokeWidth = 1,
                    BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
                    Padding = new Thickness(20, 14),
                    Children =
                    {
                        content
                    }
                }
            }
        };
    }

    private SkiaRadioButton CreateRadio(string text, EventHandler<bool> handler, bool isDefault = false, string? groupName = null)
    {
        var radio = new SkiaRadioButton(text)
        {
            WidthRequest = 112,
            MinimumHeightRequest = 24,
            DefaultValue = isDefault,
            GroupName = groupName ?? string.Empty,
            ColorFrameOff = new Color(0.816f, 0.816f, 0.816f, 1f),
            ColorFrameOn = new Color(0.208f, 0.447f, 0.761f, 1f),
            ColorThumbOn = new Color(0.208f, 0.447f, 0.761f, 1f),
            ColorThumbOff = new Color(0.365f, 0.314f, 0.231f, 1f),
            HorizontalOptions = LayoutOptions.Start,
            VerticalOptions = LayoutOptions.Center,
            Children =
            {
                new SkiaLayout()
                {
                    WidthRequest = 24,
                    HeightRequest = 24,
                    VerticalOptions = LayoutOptions.Center,
                    HorizontalOptions = LayoutOptions.Start,
                    Children =
                    {
                        new SkiaShape()
                        {
                            HorizontalOptions = LayoutOptions.Fill,
                            VerticalOptions = LayoutOptions.Fill,
                            StrokeColor = new Color(0.110f, 0.251f, 0.443f, 1f),
                            StrokeWidth = 2,
                            Type = ShapeType.Circle
                        },
                        new SkiaShape()
                        {
                            BackgroundColor = new Color(0.208f, 0.447f, 0.761f, 1f),
                            HorizontalOptions = LayoutOptions.Center,
                            VerticalOptions = LayoutOptions.Center,
                            WidthRequest = 12,
                            HeightRequest = 12,
                            Type = ShapeType.Circle,
                            Tag = "On"
                        }
                    }
                },
                new SkiaLabel()
                {
                    Margin = new Thickness(32, 0, 0, 0),
                    FontFamily = "FontText",
                    FontSize = 14,
                    LineBreakMode = LineBreakMode.WordWrap,
                    MaxLines = 2,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    VerticalOptions = LayoutOptions.Center,
                    Tag = "Text"
                }
            }
        };

        radio.Toggled += handler;
        return radio;
    }

    private void OnContainerGroupChanged(object? sender, bool isOn)
    {
        _containerSummaryLabel.Text = $"Container group: {GetSelectedText(_containerGroupRadios)}";
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnNamedGroupChanged(object? sender, bool isOn)
    {
        _namedSummaryLabel.Text = $"Named group: {GetSelectedText(_namedGroupRadios)}";
        _ = InvokeAsync(StateHasChanged);
    }

    private static string GetSelectedText(IEnumerable<SkiaRadioButton> radios)
    {
        return radios.FirstOrDefault(radio => radio.IsToggled)?.Text ?? "None";
    }

    protected override void OnInitialized()
    {
        _containerSummaryLabel.Text = $"Container group: {GetSelectedText(_containerGroupRadios)}";
        _namedSummaryLabel.Text = $"Named group: {GetSelectedText(_namedGroupRadios)}";
        _ = InvokeAsync(StateHasChanged);
    }
}