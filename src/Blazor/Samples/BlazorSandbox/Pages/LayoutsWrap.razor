@page "/layouts-wrap"
@using DrawnUi
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaWrap</PageTitle>

<div class="docs-page">
    <h1>SkiaWrap</h1>
    <p class="docs-lead">SkiaWrap is the responsive wrapping alias for SkiaLayout. It fixes <strong>Type = LayoutType.Wrap</strong> so children flow into the next line when the available width runs out.</p>
    <p class="docs-note">Use it for chips, tags, quick filters, or compact control groups that should reflow without writing grid definitions.</p>

    <div class="docs-example-frame">
        <Canvas Content="_canvasContent" WidthRequest="360"
                HeightRequest="324"
                BackgroundColor="#F6F0E6"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                 />
    </div>

    <pre class="docs-code"><code>@WrapSnippet</code></pre>
</div>

@code {
    private const string WrapSnippet = """
var wrap = new SkiaWrap()
{
    Spacing = 10,
    Children =
    {
        new SkiaShape() { WidthRequest = 84, HeightRequest = 40 },
        new SkiaShape() { WidthRequest = 84, HeightRequest = 40 },
        new SkiaShape() { WidthRequest = 84, HeightRequest = 40 }
    }
};
""";

    private SkiaControl _canvasContent;

    public LayoutsWrap()
    {
        var wrap = new SkiaWrap()
        {
            WidthRequest = 220,
            Spacing = 10,
            HorizontalOptions = LayoutOptions.Center,
            Children =
            {
                CreateWrapChip("Primary", new Color(0.918f, 0.941f, 0.976f, 1f)),
                CreateWrapChip("Filter", new Color(0.961f, 0.925f, 0.898f, 1f)),
                CreateWrapChip("Selected", new Color(0.922f, 0.961f, 0.929f, 1f)),
                CreateWrapChip("Small", new Color(0.973f, 0.953f, 0.906f, 1f)),
                CreateWrapChip("Overflow", new Color(0.937f, 0.925f, 0.976f, 1f))
            }
        };

        _canvasContent = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 328,
            HeightRequest = 292,
            Padding = new Thickness(18),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Type = LayoutType.Column,
            Spacing = 12,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaWrap",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                wrap
            }
        };
    }

    private static SkiaShape CreateWrapChip(string text, Color color)
    {
        return new SkiaShape()
        {
            WidthRequest = 92,
            HeightRequest = 40,
            Type = ShapeType.Rectangle,
            CornerRadius = 20,
            BackgroundColor = color,
            Children =
            {
                new SkiaLabel()
                {
                    Text = text,
                    FontFamily = "FontText",
                    FontSize = 13,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Center,
                    VerticalOptions = LayoutOptions.Center
                }
            }
        };
    }
}