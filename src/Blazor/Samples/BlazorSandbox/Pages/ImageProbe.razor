@page "/image-probe"
@using DrawnUi.Draw
@using DrawnUi.Views
@using DrawnUi.Infrastructure.Xaml

@using DrawnUi

<PageTitle>Image Probe</PageTitle>

<h1>Image Probe</h1>

<p id="image-probe-description">Use this page to validate the first Blazor backup of SkiaImage.</p>

<Canvas
    WidthRequest="420"
    HeightRequest="760"
    BackgroundColor="#F4F1E8"
    Margin="0,16,0,32"
    RootControl="@RootControl" />

@code {
    private readonly SkiaControl RootControl;

    public ImageProbe()
    {
        SkiaImage.LogEnabled = true;
        SkiaImageManager.LogEnabled = true;

        var faviconImage = CreateProbeImage("favicon", "favicon.png", TransformAspect.AspectFit);
        var iconImage = CreateProbeImage("icon-192", "icon-192.png", TransformAspect.AspectFit);
        var remoteImage = CreateProbeImage("remote", "https://picsum.photos/440/280", TransformAspect.AspectCover, eraseChangedContent: true);

        RootControl = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 388,
            HeightRequest = 720,
            Padding = new Thickness(20),
            BackgroundColor = new Color(0.996f, 0.992f, 0.965f, 1f),
            Type = LayoutType.Column,
            Spacing = 16,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaImage backup probe",
                    FontFamily = "FontTextTitle",
                    FontSize = 28,
                    TextColor = new Color(0.145f, 0.169f, 0.216f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                new SkiaLabel()
                {
                    Text = "Expected: three images rendered below, without touching Home.",
                    FontFamily = "FontText",
                    FontSize = 15,
                    TextColor = new Color(0.255f, 0.286f, 0.353f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                CreateCard(
                    "Local favicon via FileImageSource",
                    faviconImage),
                CreateCard(
                    "Local icon via FileImageSource",
                    iconImage),
                CreateCard(
                    "Remote bitmap via UriImageSource",
                    remoteImage)
            }
        };
    }

    private SkiaImage CreateProbeImage(string key, ImageSource source, TransformAspect aspect, bool eraseChangedContent = false)
    {
        var image = new SkiaImage()
        {
            HorizontalOptions = LayoutOptions.Fill,
            VerticalOptions = LayoutOptions.Fill,
            BackgroundColor = Colors.Green,
            Source = source,
            Aspect = aspect,
            EraseChangedContent = eraseChangedContent
        };

        image.Success += (_, _) => UpdateStatus($"{key}: success");
        image.Error += (_, _) => UpdateStatus($"{key}: error");

        return image;
    }

    private void UpdateStatus(string message)
    {
        Console.WriteLine($"[ImageProbe] {message}");
    }

    private static SkiaShape CreateCard(string title, SkiaImage image)
    {
        return new SkiaShape()
        {
            WidthRequest = 348,
            HeightRequest = 200,
            Type = ShapeType.Rectangle,
            CornerRadius = 18,
            BackgroundColor = new Color(0.949f, 0.929f, 0.878f, 1f),
            StrokeColor = Colors.Black,
            StrokeWidth = 1,
            Children =
            {
                new SkiaStack()
                {
                    Spacing = 0,
                    BackgroundColor = Colors.White,
                    VerticalOptions = LayoutOptions.Fill,
                    Children =
                    {
                        new SkiaLabel()
                        {
                            Text = title,
                            //Padding = new(4,0),
                            FontFamily = "FontTextTitle",
                            FontSize = 18,
                            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
                            HorizontalOptions = LayoutOptions.Fill
                        },
                        image,
                    }
                }
            }
        };
    }
}