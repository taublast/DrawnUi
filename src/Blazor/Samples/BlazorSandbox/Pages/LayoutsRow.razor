@page "/layouts-row"
@using DrawnUi
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaRow</PageTitle>

<div class="docs-page">
    <h1>SkiaRow</h1>
    <p class="docs-lead">SkiaRow is the horizontal-stack alias for SkiaLayout. It fixes <strong>Type = LayoutType.Row</strong> so children are laid out left-to-right without repeating the base configuration.</p>
    <p class="docs-note">Use it when the intent is clearly a horizontal flow. It keeps the code shorter than a raw SkiaLayout setup while still staying inside the same DrawnUI layout system.</p>

    <div class="docs-example-frame">
        <Canvas Content="_canvasContent" WidthRequest="360"
                HeightRequest="324"
                BackgroundColor="#F6F0E6"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                 />
    </div>

    <pre class="docs-code"><code>@RowSnippet</code></pre>
</div>

@code {
    private const string RowSnippet = """
var row = new SkiaRow()
{
    Spacing = 10,
    Children =
    {
        new SkiaShape() { WidthRequest = 64, HeightRequest = 64 },
        new SkiaShape() { WidthRequest = 64, HeightRequest = 64 },
        new SkiaShape() { WidthRequest = 64, HeightRequest = 64 }
    }
};
""";

    private SkiaControl _canvasContent;

    public LayoutsRow()
    {
        var row = new SkiaRow()
        {
            Spacing = 10,
            HorizontalOptions = LayoutOptions.Center,
            Children =
            {
                CreateRowTile("Left", new Color(0.918f, 0.941f, 0.976f, 1f)),
                CreateRowTile("Center", new Color(0.961f, 0.925f, 0.898f, 1f)),
                CreateRowTile("Right", new Color(0.922f, 0.961f, 0.929f, 1f))
            }
        };

        _canvasContent = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 328,
            HeightRequest = 292,
            Padding = new Thickness(18),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Type = LayoutType.Column,
            Spacing = 12,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaRow",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                row
            }
        };
    }

    private static SkiaShape CreateRowTile(string text, Color color)
    {
        return new SkiaShape()
        {
            WidthRequest = 76,
            HeightRequest = 92,
            Type = ShapeType.Rectangle,
            CornerRadius = 16,
            BackgroundColor = color,
            Children =
            {
                new SkiaLabel()
                {
                    Text = text,
                    FontFamily = "FontTextTitle",
                    FontSize = 14,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Center,
                    VerticalOptions = LayoutOptions.Center
                }
            }
        };
    }
}