@page "/scrolls-drawer"
@using DrawnUi
@using DrawnUi.Controls
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaDrawer</PageTitle>

<div class="docs-page">
    <h1>SkiaDrawer</h1>
    <p class="docs-lead">SkiaDrawer is a snapping panel that can slide from any side while keeping its content in the DrawnUI tree. It works well for sheets, details panels, maps overlays, and contextual tools.</p>
    <p class="docs-note">Use the button or drag the sheet handle. The drawer content here is just a small vertical scroll to keep the example focused.</p>

    <div class="docs-example-frame">
        <Canvas Content="_canvasContent" WidthRequest="360"
                HeightRequest="420"
                BackgroundColor="#F6F0E6"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                 />
    </div>

    <pre class="docs-code"><code>@DrawerSnippet</code></pre>
</div>

@code {
    private const string DrawerSnippet = """
var drawer = new SkiaDrawer()
{
    Direction = DrawnUi.Infrastructure.Enums.DrawerDirection.FromBottom,
    HeaderSize = 36,
    IsOpen = false
};
""";

    private readonly SkiaDrawer _drawer;
    private readonly SkiaButton _toggleButton;
    private SkiaControl _canvasContent;

    public ScrollsDrawer()
    {
        var drawerContent = new SkiaLayout()
        {
            HorizontalOptions = LayoutOptions.Fill,
            VerticalOptions = LayoutOptions.Fill,
            Children =
            {
                new SkiaShape()
                {
                    HeightRequest = 36,
                    BackgroundColor = new Color(0.847f, 0.255f, 0.255f, 1f),
                    CornerRadius = 18,
                    Children =
                    {
                        new SkiaLabel()
                        {
                            Text = "Drag me",
                            FontFamily = "FontTextTitle",
                            FontSize = 14,
                            TextColor = Colors.White,
                            HorizontalOptions = LayoutOptions.Center,
                            VerticalOptions = LayoutOptions.Center
                        }
                    }
                },
                new SkiaScroll()
                {
                    AddMarginTop = 36,
                    BackgroundColor = new Color(0.957f, 0.957f, 0.957f, 1f),
                    HorizontalOptions = LayoutOptions.Fill,
                    VerticalOptions = LayoutOptions.Fill,
                    Content = CreateDrawerList()
                }
            }
        };

        _drawer = new SkiaDrawer()
        {
            WidthRequest = 292,
            HeightRequest = 250,
            HeaderSize = 36,
            Direction = DrawerDirection.FromBottom,
            IsOpen = false,
            HorizontalOptions = LayoutOptions.Center,
            VerticalOptions = LayoutOptions.End,
            Content = drawerContent
        };

        _toggleButton = new SkiaButton("Open drawer")
        {
            WidthRequest = 124,
            HeightRequest = 38,
            BackgroundColor = new Color(0.157f, 0.278f, 0.420f, 1f),
            TextColor = Colors.White,
            CornerRadius = 10,
            HorizontalOptions = LayoutOptions.Start
        };
        _toggleButton.Tapped += (_, _) => ToggleDrawer();

        _canvasContent = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 328,
            HeightRequest = 388,
            Padding = new Thickness(18),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Type = LayoutType.Column,
            Spacing = 12,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaDrawer",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                _toggleButton,
                new SkiaShape()
                {
                    WidthRequest = 292,
                    HeightRequest = 274,
                    Type = ShapeType.Rectangle,
                    CornerRadius = 20,
                    BackgroundColor = new Color(0.918f, 0.941f, 0.976f, 1f),
                    HorizontalOptions = LayoutOptions.Center,
                    VerticalOptions = LayoutOptions.Fill,
                    Children =
                    {
                        new SkiaLabel()
                        {
                            Text = "Sheet host",
                            FontFamily = "FontTextTitle",
                            FontSize = 18,
                            TextColor = new Color(0.157f, 0.278f, 0.420f, 1f),
                            HorizontalOptions = LayoutOptions.Center,
                            VerticalOptions = LayoutOptions.Start,
                            Margin = new Thickness(0, 16, 0, 0)
                        },
                        _drawer
                    }
                }
            }
        };
    }

    private void ToggleDrawer()
    {
        _drawer.IsOpen = !_drawer.IsOpen;
        _toggleButton.Text = _drawer.IsOpen ? "Close drawer" : "Open drawer";
        _ = InvokeAsync(StateHasChanged);
    }

    private static SkiaLayout CreateDrawerList()
    {
        var layout = new SkiaLayout()
        {
            Margin = new Thickness(8),
            AddMarginBottom = 10,
            Type = LayoutType.Column,
            Spacing = 10,
            UseCache = SkiaCacheType.Image
        };

        for (var index = 0; index < 5; index++)
        {
            layout.AddSubView(new SkiaShape()
            {
                WidthRequest = 244,
                HeightRequest = 52,
                Type = ShapeType.Rectangle,
                CornerRadius = 14,
                BackgroundColor = index % 2 == 0 ? new Color(0.961f, 0.925f, 0.898f, 1f) : new Color(0.918f, 0.941f, 0.976f, 1f),
                HorizontalOptions = LayoutOptions.Center,
                Children =
                {
                    new SkiaLabel()
                    {
                        Text = $"Drawer item {index + 1}",
                        FontFamily = "FontText",
                        FontSize = 14,
                        TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
                        HorizontalOptions = LayoutOptions.Center,
                        VerticalOptions = LayoutOptions.Center
                    }
                }
            });
        }

        return layout;
    }
}