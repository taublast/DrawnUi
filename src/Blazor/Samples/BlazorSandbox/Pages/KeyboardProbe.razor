@page "/keyboard-probe"
@using DrawnUi.Draw
@using DrawnUi.Views

@using DrawnUi
@implements IDisposable

<PageTitle>Keyboard Probe</PageTitle>

<h1>Keyboard Probe</h1>

Use this page to verify `UseDesktopKeyboard` in Blazor. Keep this tab active and press keys.

<p id="keyboard-probe-last">@_lastKeyText</p>
<p id="keyboard-probe-modifiers">@_modifierText</p>

<ul id="keyboard-probe-history">
    @foreach (var item in _history)
    {
        <li>@item</li>
    }
</ul>

<Canvas
    WidthRequest="400"
    HeightRequest="520"
    BackgroundColor="#F4F1E8"
    Margin="0,16,0,0"
    Content="_canvasContent" />

@code {
    private readonly SkiaLabel _heroLabel = new()
    {
        Text = "Keyboard probe ready",
        FontFamily = "FontTextTitle",
        FontSize = 28,
        TextColor = new Color(0.145f, 0.169f, 0.216f, 1f),
        HorizontalOptions = LayoutOptions.Fill
    };

    private readonly SkiaLabel _lastKeyLabel = new()
    {
        Text = "Last key: waiting",
        FontFamily = "FontText",
        FontSize = 16,
        TextColor = new Color(0.255f, 0.286f, 0.353f, 1f),
        HorizontalOptions = LayoutOptions.Fill
    };

    private readonly SkiaLabel _modifierLabel = new()
    {
        Text = "Modifiers: shift false, ctrl false, alt false",
        FontFamily = "FontText",
        FontSize = 14,
        TextColor = new Color(0.388f, 0.435f, 0.502f, 1f),
        HorizontalOptions = LayoutOptions.Fill
    };

    private readonly SkiaLabel[] _historyLabels =
    {
        CreateHistoryLabel(),
        CreateHistoryLabel(),
        CreateHistoryLabel(),
        CreateHistoryLabel(),
        CreateHistoryLabel()
    };

    private readonly List<string> _history =
    [
        "Waiting for input",
        "Waiting for input",
        "Waiting for input",
        "Waiting for input",
        "Waiting for input"
    ];

    private SkiaControl _canvasContent;

    private string _lastKeyText = "Last key: waiting";
    private string _modifierText = "Modifiers: shift false, ctrl false, alt false";

    public KeyboardProbe()
    {
        _canvasContent = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 368,
            HeightRequest = 488,
            Padding = new Thickness(20),
            BackgroundColor = new Color(0.996f, 0.992f, 0.965f, 1f),
            Type = LayoutType.Column,
            Spacing = 14,
            Children =
            {
                _heroLabel,
                new SkiaShape()
                {
                    WidthRequest = 328,
                    HeightRequest = 92,
                    Type = ShapeType.Rectangle,
                    CornerRadius = 18,
                    BackgroundColor = new Color(0.235f, 0.388f, 0.624f, 1f),
                    Padding = new Thickness(16),
                    Children =
                    {
                        new SkiaLabel()
                        {
                            Text = "Press letters, arrows, modifiers, or function keys",
                            FontFamily = "FontText",
                            FontSize = 18,
                            TextColor = Colors.White,
                            HorizontalOptions = LayoutOptions.Fill,
                            VerticalOptions = LayoutOptions.Center
                        }
                    }
                },
                _lastKeyLabel,
                _modifierLabel,
                new SkiaLayout()
                {
                    WidthRequest = 328,
                    Padding = new Thickness(14),
                    BackgroundColor = new Color(0.949f, 0.929f, 0.878f, 1f),
                    Type = LayoutType.Column,
                    Spacing = 8,
                    Children =
                    {
                        new SkiaLabel()
                        {
                            Text = "Recent events",
                            FontFamily = "FontTextTitle",
                            FontSize = 18,
                            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
                            HorizontalOptions = LayoutOptions.Fill
                        },
                        _historyLabels[0],
                        _historyLabels[1],
                        _historyLabels[2],
                        _historyLabels[3],
                        _historyLabels[4]
                    }
                }
            }
        };
    }

    protected override void OnInitialized()
    {
        KeyboardManager.KeyDown += OnKeyDown;
        KeyboardManager.KeyUp += OnKeyUp;
    }

    public void Dispose()
    {
        KeyboardManager.KeyDown -= OnKeyDown;
        KeyboardManager.KeyUp -= OnKeyUp;
    }

    private void OnKeyDown(object? sender, InputKey key)
    {
        ApplyKeyboardState("down", key);
    }

    private void OnKeyUp(object? sender, InputKey key)
    {
        ApplyKeyboardState("up", key);
    }

    private void ApplyKeyboardState(string phase, InputKey key)
    {
        _lastKeyText = $"Last key: {phase} {key}";
        _modifierText = BuildModifierText();

        _heroLabel.Text = "Keyboard probe live";
        _lastKeyLabel.Text = _lastKeyText;
        _modifierLabel.Text = _modifierText;

        _history.Insert(0, $"{phase} {key}");
        if (_history.Count > _historyLabels.Length)
        {
            _history.RemoveAt(_history.Count - 1);
        }

        for (var index = 0; index < _historyLabels.Length; index++)
        {
            _historyLabels[index].Text = _history[index];
        }

        _ = InvokeAsync(StateHasChanged);
    }

    private static string BuildModifierText()
    {
        return $"Modifiers: shift {KeyboardManager.IsShiftPressed.ToString().ToLowerInvariant()}, ctrl {KeyboardManager.IsControlPressed.ToString().ToLowerInvariant()}, alt {KeyboardManager.IsAltPressed.ToString().ToLowerInvariant()}";
    }

    private static SkiaLabel CreateHistoryLabel()
    {
        return new SkiaLabel()
        {
            Text = "Waiting for input",
            FontFamily = "FontText",
            FontSize = 14,
            TextColor = new Color(0.255f, 0.286f, 0.353f, 1f),
            HorizontalOptions = LayoutOptions.Fill
        };
    }
}