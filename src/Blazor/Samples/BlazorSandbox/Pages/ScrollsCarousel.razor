@page "/scrolls-carousel"
@using DrawnUi
@using DrawnUi.Controls
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaCarousel</PageTitle>

<div class="docs-page">
    <h1>SkiaCarousel</h1>
    <p class="docs-lead">SkiaCarousel is a snapping scroll surface for swipeable pages, galleries, and cards. Use it when the content should land on discrete items instead of resting at arbitrary offsets.</p>
    <p class="docs-note">Swipe the cards or use the buttons. The selected index label follows the active slide.</p>

    <div class="docs-example-frame">
        <Canvas WidthRequest="360"
                HeightRequest="388"
                BackgroundColor="#F6F0E6"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                RootControl="@RootControl" />
    </div>

    <pre class="docs-code"><code>@CarouselSnippet</code></pre>
</div>

@code {
    private const string CarouselSnippet = """
var carousel = new SkiaCarousel()
{
    SidesOffset = 32,
    Spacing = 16,
    SelectedIndex = 0
};
""";

    private readonly SkiaCarousel _carousel;
    private readonly SkiaLabel _statusLabel;
    private readonly SkiaControl RootControl;

    public ScrollsCarousel()
    {
        _statusLabel = new SkiaLabel()
        {
            Text = "Selected slide: 1",
            FontFamily = "FontText",
            FontSize = 13,
            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
            HorizontalOptions = LayoutOptions.Fill,
            HorizontalTextAlignment = DrawTextAlignment.Center
        };

        _carousel = new SkiaCarousel()
        {
            WidthRequest = 292,
            HeightRequest = 178,
            BackgroundColor = new Color(0.094f, 0.137f, 0.243f, 1f),
            SidesOffset = 32,
            Spacing = 16,
            SelectedIndex = 0,
            HorizontalOptions = LayoutOptions.Center,
            Children =
            {
                CreateSlide("A", new Color(0.914f, 0.271f, 0.376f, 1f)),
                CreateSlide("B", new Color(0.059f, 0.204f, 0.376f, 1f)),
                CreateSlide("C", new Color(0.325f, 0.204f, 0.514f, 1f)),
                CreateSlide("D", new Color(0.659f, 0.875f, 0.557f, 1f), new Color(0.102f, 0.102f, 0.180f, 1f))
            }
        };

        _carousel.SelectedIndexChanged += OnSelectedIndexChanged;

        RootControl = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 328,
            HeightRequest = 356,
            Padding = new Thickness(18),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Type = LayoutType.Column,
            Spacing = 12,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaCarousel",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                _carousel,
                new SkiaLayout()
                {
                    WidthRequest = 292,
                    Type = LayoutType.Row,
                    Spacing = 12,
                    HorizontalOptions = LayoutOptions.Center,
                    Children =
                    {
                        CreateNavButton("Prev", -1),
                        CreateNavButton("Next", 1)
                    }
                },
                _statusLabel
            }
        };
    }

    private void OnSelectedIndexChanged(object? sender, int index)
    {
        _statusLabel.Text = $"Selected slide: {index + 1}";
        _ = InvokeAsync(StateHasChanged);
    }

    private SkiaButton CreateNavButton(string text, int step)
    {
        var button = new SkiaButton(text)
        {
            WidthRequest = 96,
            HeightRequest = 38,
            BackgroundColor = new Color(0.157f, 0.278f, 0.420f, 1f),
            TextColor = Colors.White,
            CornerRadius = 10,
            HorizontalOptions = LayoutOptions.Center
        };

        button.Tapped += (_, _) =>
        {
            var next = Math.Clamp(_carousel.SelectedIndex + step, 0, _carousel.ChildrenCount - 1);
            _carousel.SelectedIndex = next;
        };

        return button;
    }

    private static SkiaLayout CreateSlide(string label, Color backgroundColor, Color? textColor = null)
    {
        return new SkiaLayout()
        {
            BackgroundColor = backgroundColor,
            UseCache = SkiaCacheType.Operations,
            Children =
            {
                new SkiaLabel()
                {
                    Text = label,
                    FontFamily = "FontTextTitle",
                    FontSize = 60,
                    TextColor = textColor ?? Colors.White,
                    HorizontalOptions = LayoutOptions.Center,
                    VerticalOptions = LayoutOptions.Center
                }
            }
        };
    }
}