@page "/shapes-probe"
@using DrawnUi.Draw
@using DrawnUi.Views
@using DrawnUi.Infrastructure.Xaml

@using DrawnUi

<PageTitle>Shapes Probe</PageTitle>

<h1>Shapes Probe</h1>

<p id="shapes-probe-description">Use this page to validate SkiaShape clipping, stroke-aware children rects, and rounded shape content in Blazor.</p>

<Canvas
    WidthRequest="420"
    HeightRequest="860"
    BackgroundColor="#F4F1E8"
    Margin="0,16,0,32"
    RootControl="@RootControl" />

@code {
    private readonly SkiaControl RootControl;

    public ShapesProbe()
    {
        RootControl = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 388,
            HeightRequest = 820,
            Padding = new Thickness(20),
            BackgroundColor = new Color(0.996f, 0.992f, 0.965f, 1f),
            Type = LayoutType.Column,
            Spacing = 18,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaShape probe",
                    FontFamily = "FontTextTitle",
                    FontSize = 28,
                    TextColor = new Color(0.145f, 0.169f, 0.216f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                new SkiaLabel()
                {
                    Text = "Expected: child content stays inside the stroked rounded shape, and the interior rect shrinks with the stroke.",
                    FontFamily = "FontText",
                    FontSize = 15,
                    TextColor = new Color(0.255f, 0.286f, 0.353f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                CreateImageCard("Rounded card with thick stroke", ImageSource.FromUri(new Uri("https://picsum.photos/600/360"))),
                CreateInsetCard("Inset fill test"),
                CreateCircleClipCard("Circle clip test")
            }
        };
    }

    private static SkiaShape CreateImageCard(string title, ImageSource source)
    {
        return new SkiaShape()
        {
            WidthRequest = 348,
            HeightRequest = 220,
            Type = ShapeType.Rectangle,
            CornerRadius = 24,
            BackgroundColor = new Color(0.949f, 0.929f, 0.878f, 1f),
            StrokeColor = Colors.Black,
            StrokeWidth = 14,
            Children =
            {
                new SkiaStack()
                {
                    Spacing = 0,
                    BackgroundColor = new Color(1f, 1f, 1f, 0.7f),
                    VerticalOptions = LayoutOptions.Fill,
                    Children =
                    {
                        new SkiaLabel()
                        {
                            Text = title,
                            FontFamily = "FontTextTitle",
                            FontSize = 18,
                            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
                            HorizontalOptions = LayoutOptions.Fill
                        },
                        new SkiaImage()
                        {
                            HorizontalOptions = LayoutOptions.Fill,
                            VerticalOptions = LayoutOptions.Fill,
                            Source = source,
                            Aspect = TransformAspect.AspectCover,
                            EraseChangedContent = true
                        }
                    }
                }
            }
        };
    }

    private static SkiaShape CreateInsetCard(string title)
    {
        return new SkiaShape()
        {
            WidthRequest = 348,
            HeightRequest = 180,
            Type = ShapeType.Rectangle,
            CornerRadius = 22,
            BackgroundColor = new Color(0.949f, 0.929f, 0.878f, 1f),
            StrokeColor = Colors.Black,
            StrokeWidth = 18,
            Padding = new Thickness(12),
            Children =
            {
                new SkiaShape()
                {
                    Type = ShapeType.Rectangle,
                    CornerRadius = 12,
                    BackgroundColor = new Color(0.220f, 0.365f, 0.624f, 1f),
                    HorizontalOptions = LayoutOptions.Fill,
                    VerticalOptions = LayoutOptions.Fill,
                    Children =
                    {
                        new SkiaLabel()
                        {
                            Text = title,
                            FontFamily = "FontTextTitle",
                            FontSize = 20,
                            TextColor = Colors.White,
                            Margin = new Thickness(14),
                            HorizontalOptions = LayoutOptions.Fill,
                            VerticalOptions = LayoutOptions.Start
                        }
                    }
                }
            }
        };
    }

    private static SkiaShape CreateCircleClipCard(string title)
    {
        return new SkiaShape()
        {
            WidthRequest = 220,
            HeightRequest = 220,
            Type = ShapeType.Circle,
            BackgroundColor = new Color(0.949f, 0.929f, 0.878f, 1f),
            StrokeColor = Colors.Black,
            StrokeWidth = 16,
            HorizontalOptions = LayoutOptions.Center,
            Children =
            {
                new SkiaImage()
                {
                    HorizontalOptions = LayoutOptions.Fill,
                    VerticalOptions = LayoutOptions.Fill,
                    Source = ImageSource.FromUri(new Uri("https://picsum.photos/480/480")),
                    Aspect = TransformAspect.AspectCover,
                    EraseChangedContent = true
                },
                new SkiaLabel()
                {
                    Text = title,
                    FontFamily = "FontTextTitle",
                    FontSize = 18,
                    TextColor = Colors.White,
                    HorizontalOptions = LayoutOptions.Center,
                    VerticalOptions = LayoutOptions.Center
                }
            }
        };
    }
}