@page "/layouts-tabs-selector"
@using DrawnUi
@using DrawnUi.Controls
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaTabsSelector</PageTitle>

<div class="docs-page">
    <h1>SkiaTabsSelector</h1>
    <p class="docs-lead">SkiaTabsSelector treats a chosen child type as a selectable tab row. It is the lightest way to coordinate tab selection state before you attach the chosen index to a carousel, a view switcher, or another drawn surface.</p>
    <p class="docs-note">Tap the labels in the tab strip. The selector updates the selected index and this demo recolors the active tab to make the state obvious.</p>

    <div class="docs-example-frame">
        <Canvas WidthRequest="360"
                HeightRequest="316"
                BackgroundColor="#F6F0E6"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                RootControl="@RootControl" />
    </div>

    <pre class="docs-code"><code>@TabsSnippet</code></pre>
</div>

@code {
    private const string TabsSnippet = """
var tabs = new SkiaTabsSelector()
{
    SelectedIndex = 0,
    Children = { tabOne, tabTwo, tabThree }
};
""";

    private readonly DemoTabsSelector _tabs;
    private readonly SkiaLabel _statusLabel;
    private readonly SkiaControl RootControl;

    public LayoutsTabsSelector()
    {
        _statusLabel = new SkiaLabel()
        {
            Text = "Selected tab: Overview",
            FontFamily = "FontText",
            FontSize = 13,
            TextColor = new Color(0.278f, 0.196f, 0.110f, 1f),
            HorizontalOptions = LayoutOptions.Fill,
            HorizontalTextAlignment = DrawTextAlignment.Center
        };

        var tabs = new List<SkiaLabel>
        {
            CreateTabLabel("Overview", 0),
            CreateTabLabel("Analytics", 1),
            CreateTabLabel("Settings", 2)
        };

        _tabs = new DemoTabsSelector(tabs, OnTabChanged)
        {
            WidthRequest = 292,
            HeightRequest = 46,
            BackgroundColor = new Color(0.098f, 0.118f, 0.184f, 1f),
            Type = LayoutType.Row,
            Spacing = 8,
            Padding = new Thickness(8, 6),
            SelectedIndex = 0,
            HorizontalOptions = LayoutOptions.Center,
            Children = tabs.Cast<SkiaControl>().ToList()
        };

        _tabs.ApplyVisualState();

        RootControl = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 328,
            HeightRequest = 284,
            Padding = new Thickness(18),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Type = LayoutType.Column,
            Spacing = 12,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaTabsSelector",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                _tabs,
                _statusLabel,
                new SkiaLabel()
                {
                    Text = "In larger samples, this selected index usually drives a carousel or view-switching surface.",
                    FontFamily = "FontText",
                    FontSize = 13,
                    TextColor = new Color(0.365f, 0.314f, 0.231f, 1f),
                    HorizontalOptions = LayoutOptions.Fill,
                    WidthRequest = 248
                }
            }
        };
    }

    private SkiaLabel CreateTabLabel(string text, int index)
    {
        var label = new SkiaLabel()
        {
            WidthRequest = 86,
            FontFamily = "FontTextTitle",
            FontSize = 14,
            Text = text,
            TextColor = new Color(0.788f, 0.808f, 0.843f, 1f),
            HorizontalOptions = LayoutOptions.Center,
            VerticalOptions = LayoutOptions.Center,
            HorizontalTextAlignment = DrawTextAlignment.Center
        };

        label.Tapped += (_, _) => _tabs.SelectedIndex = index;
        return label;
    }

    private void OnTabChanged(int index, string text)
    {
        _statusLabel.Text = $"Selected tab: {text}";
        _ = InvokeAsync(StateHasChanged);
    }

    private sealed class DemoTabsSelector : SkiaTabsSelector
    {
        private readonly IReadOnlyList<SkiaLabel> _tabs;
        private readonly Action<int, string> _onChanged;

        public DemoTabsSelector(IReadOnlyList<SkiaLabel> tabs, Action<int, string> onChanged)
        {
            _tabs = tabs;
            _onChanged = onChanged;
        }

        public void ApplyVisualState()
        {
            for (var index = 0; index < _tabs.Count; index++)
            {
                var active = index == SelectedIndex;
                _tabs[index].TextColor = active ? Colors.White : new Color(0.788f, 0.808f, 0.843f, 1f);
                _tabs[index].BackgroundColor = active ? new Color(0.208f, 0.447f, 0.761f, 1f) : Colors.Transparent;
                _tabs[index].Padding = new Thickness(8, 8);
            }
        }

        public override async Task OnTabSelectionChanged(bool tabsChanged, int index)
        {
            await base.OnTabSelectionChanged(tabsChanged, index);
            ApplyVisualState();

            if (index >= 0 && index < _tabs.Count)
            {
                _onChanged(index, _tabs[index].Text);
            }
        }
    }
}