@page "/layouts-layout"
@using DrawnUi
@using DrawnUi.Draw
@using DrawnUi.Views

<PageTitle>SkiaLayout</PageTitle>

<div class="docs-page">
    <h1>SkiaLayout</h1>
    <p class="docs-lead">SkiaLayout is the universal DrawnUI layout control. Its key property is <strong>Type</strong>, which decides whether the same control behaves like an absolute layer, a vertical stack, a horizontal row, a wrap panel, or a grid.</p>
    <p class="docs-note">Many convenience controls are built on top of it, including SkiaLayer, SkiaStack, SkiaRow, and SkiaWrap. Start with SkiaLayout when you want the base primitive, then move to the specialized aliases when the intent is fixed.</p>

    <div class="docs-example-frame">
        <Canvas Content="_canvasContent" WidthRequest="360"
                HeightRequest="324"
                BackgroundColor="#F6F0E6"
                Margin="0,8,0,0"
                Gestures="@GesturesMode.Enabled"
                 />
    </div>

    <pre class="docs-code"><code>@LayoutSnippet</code></pre>
</div>

@code {
    private const string LayoutSnippet = """
var layout = new SkiaLayout()
{
    Type = LayoutType.Row,
    Spacing = 12,
    Children =
    {
        new SkiaShape() { WidthRequest = 72, HeightRequest = 72 },
        new SkiaShape() { WidthRequest = 72, HeightRequest = 72 },
        new SkiaShape() { WidthRequest = 72, HeightRequest = 72 }
    }
};
""";

    private SkiaControl _canvasContent;

    public LayoutsLayout()
    {
        var layout = new SkiaLayout()
        {
            Type = LayoutType.Row,
            Spacing = 12,
            HorizontalOptions = LayoutOptions.Center,
            Children =
            {
                CreateTile("Absolute", new Color(0.918f, 0.941f, 0.976f, 1f)),
                CreateTile("Row", new Color(0.961f, 0.925f, 0.898f, 1f)),
                CreateTile("Wrap", new Color(0.922f, 0.961f, 0.929f, 1f))
            }
        };

        _canvasContent = new SkiaLayout()
        {
            Margin = new Thickness(16),
            WidthRequest = 328,
            HeightRequest = 292,
            Padding = new Thickness(18),
            BackgroundColor = new Color(1f, 0.989f, 0.959f, 1f),
            Type = LayoutType.Column,
            Spacing = 12,
            Children =
            {
                new SkiaLabel()
                {
                    Text = "SkiaLayout",
                    FontFamily = "FontTextTitle",
                    FontSize = 24,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                new SkiaLabel()
                {
                    Text = "One control, multiple layout modes through Type.",
                    FontFamily = "FontText",
                    FontSize = 13,
                    TextColor = new Color(0.365f, 0.314f, 0.231f, 1f),
                    HorizontalOptions = LayoutOptions.Fill
                },
                layout
            }
        };
    }

    private static SkiaShape CreateTile(string text, Color color)
    {
        return new SkiaShape()
        {
            WidthRequest = 84,
            HeightRequest = 92,
            Type = ShapeType.Rectangle,
            CornerRadius = 16,
            BackgroundColor = color,
            Children =
            {
                new SkiaLabel()
                {
                    Text = text,
                    FontFamily = "FontTextTitle",
                    FontSize = 14,
                    TextColor = new Color(0.208f, 0.169f, 0.118f, 1f),
                    HorizontalOptions = LayoutOptions.Center,
                    VerticalOptions = LayoutOptions.Center
                }
            }
        };
    }
}