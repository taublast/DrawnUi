@code {
    private bool collapseNavMenu = true;
    private bool presentationGroupExpanded = true;
    private bool canvasGroupExpanded;
    private bool tutorialsGroupExpanded;
    private bool primitivesGroupExpanded;
    private bool controlsGroupExpanded;
    private bool labelsControlsGroupExpanded;
    private bool buttonsControlsGroupExpanded;
    private bool switchesControlsGroupExpanded;
    private bool pickersControlsGroupExpanded;
    private bool scrollsControlsGroupExpanded;
    private bool layoutsControlsGroupExpanded;
    private bool animatedControlsGroupExpanded;
    private bool graphicsControlsGroupExpanded;
    private bool effectsControlsGroupExpanded;
    private bool gesturesGroupExpanded;
    private bool advancedGroupExpanded;
    private bool gamingGroupExpanded;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void TogglePresentationGroup()
    {
        presentationGroupExpanded = !presentationGroupExpanded;
    }

    private void ToggleTutorialsGroup()
    {
        tutorialsGroupExpanded = !tutorialsGroupExpanded;
    }

    private void ToggleCanvasGroup()
    {
        canvasGroupExpanded = !canvasGroupExpanded;
    }

    private void TogglePrimitivesGroup()
    {
        primitivesGroupExpanded = !primitivesGroupExpanded;
    }

    private void ToggleControlsGroup()
    {
        controlsGroupExpanded = !controlsGroupExpanded;
    }

    private void ToggleLabelsControlsGroup()
    {
        labelsControlsGroupExpanded = !labelsControlsGroupExpanded;
    }

    private void ToggleButtonsControlsGroup()
    {
        buttonsControlsGroupExpanded = !buttonsControlsGroupExpanded;
    }

    private void ToggleSwitchesControlsGroup()
    {
        switchesControlsGroupExpanded = !switchesControlsGroupExpanded;
    }

    private void TogglePickersControlsGroup()
    {
        pickersControlsGroupExpanded = !pickersControlsGroupExpanded;
    }

    private void ToggleScrollsControlsGroup()
    {
        scrollsControlsGroupExpanded = !scrollsControlsGroupExpanded;
    }

    private void ToggleLayoutsControlsGroup()
    {
        layoutsControlsGroupExpanded = !layoutsControlsGroupExpanded;
    }

    private void ToggleAnimatedControlsGroup()
    {
        animatedControlsGroupExpanded = !animatedControlsGroupExpanded;
    }

    private void ToggleGraphicsControlsGroup()
    {
        graphicsControlsGroupExpanded = !graphicsControlsGroupExpanded;
    }

    private void ToggleEffectsControlsGroup()
    {
        effectsControlsGroupExpanded = !effectsControlsGroupExpanded;
    }

    private void ToggleGesturesGroup()
    {
        gesturesGroupExpanded = !gesturesGroupExpanded;
    }

    private void ToggleAdvancedGroup()
    {
        advancedGroupExpanded = !advancedGroupExpanded;
    }

    private void ToggleGamingGroup()
    {
        gamingGroupExpanded = !gamingGroupExpanded;
    }

    private void CloseNavMenu()
    {
        collapseNavMenu = true;
    }
}
