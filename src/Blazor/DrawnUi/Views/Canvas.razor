@namespace DrawnUi.Views
@using AppoMobi.Gestures
@using DrawnUi.Draw
@using Microsoft.AspNetCore.Components
@using DrawnUi
@using Microsoft.JSInterop
@using System
@inherits DrawnView
@implements IAsyncDisposable
@inject IJSRuntime JS

@if (IsVisible)
{

<div class="xaml-element xaml-contentview xaml-canvas @CanvasLayoutClass @Class"
    @ref="_hostElement"
    style="@CssMargins @CssPadding @CssGridPosition @CssStyle @GestureStyle">

    <div class="xaml-canvas-surface">
        @if(RenderingMode == RenderingModeType.Default)
        {
            <SkiaView Superview="@this" DrawHandler="DrawFrame"
                      Width="@CanvasElementWidth" Height="@CanvasElementHeight" />
        }
        else
        {
            <SkiaViewAccelerated Superview="@this" DrawHandler="DrawFrame"
                                Width="@CanvasElementWidth" Height="@CanvasElementHeight" />
        }
    </div>

    @*<div class="xaml-canvas-content">
    @ChildContent
    </div> *@
    </div>

}

<style>
    .xaml-canvas {
        position: relative;
        overflow: hidden;
    }

    .xaml-canvas:fullscreen,
    .xaml-canvas:-webkit-full-screen {
        width: 100vw !important;
        height: 100vh !important;
        max-width: none !important;
        max-height: none !important;
    }

    .xaml-canvas-fill {
        flex: 1 1 auto;
        min-width: 0;
        min-height: 0;
        align-self: stretch;
    }

    .xaml-canvas-fixed {
        flex: 0 0 auto !important;
    }

    .xaml-canvas-auto {
        display: inline-block;
    }

    .xaml-canvas-surface {
        position: absolute;
        inset: 0;
        overflow: hidden;
    }

    .xaml-canvas-content {
        position: absolute;
        inset: 0;
    }
</style>

@code {

    private ElementReference _hostElement;
    private TouchEffect? _gestureEffect;
    private IJSObjectReference? _resizeModule;
    private DotNetObjectReference<Canvas>? _resizeCallbackRef;
    private float _measuredCanvasWidth;
    private float _measuredCanvasHeight;
    private bool _isBrowserFullscreen;
    private bool? _lastFullscreenRequest;

    private const string ResizeModulePath = "./_content/DrawnUi.Blazor/drawnui-canvas-resize.js";

    [Parameter]
    public SkiaControl? Content { get; set; }

    public virtual bool Focus()
    {
        return true;
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        base.BackgroundColor = ParsedBackgroundColor;
        base.Margin = ParsedMargin;
        base.RenderingMode = RenderingMode;
        base.CanRenderOffScreen = CanRenderOffScreen;
    }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();

        if (_resizeModule != null && _lastFullscreenRequest != IsFullscreen)
        {
            await SyncFullscreenAsync();
        }
    }

    protected override Task OnInitializedAsync()
    {
        if (Content != null)
        {
            SetChildren(new[]
            {
                Content
            });
        }
        else
        {
            ClearChildren();
        }

        return base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (firstRender)
        {
            SetupRenderingLoop();
            await EnsureResizeObserverAsync();
        }

        if (CaptureInput)
        {
            _gestureEffect ??= new TouchEffect(JS);
            await _gestureEffect.AttachAsync(_hostElement, this);
        }
        else if (_gestureEffect != null)
        {
            await _gestureEffect.DetachAsync();
        }

    }

    private async Task EnsureResizeObserverAsync()
    {
        _resizeModule ??= await JS.InvokeAsync<IJSObjectReference>("import", ResizeModulePath);
        _resizeCallbackRef ??= DotNetObjectReference.Create(this);

        await _resizeModule.InvokeVoidAsync("attachCanvasHost", _hostElement, _resizeCallbackRef);
    }

    [JSInvokable]
    public async Task OnHostResized(double width, double height)
    {
        if ((WidthRequest <= 0 && width <= 0) || (HeightRequest <= 0 && height <= 0))
            return;

        var nextWidth = WidthRequest > 0 && !_isBrowserFullscreen ? (float)WidthRequest : (float)Math.Round(width);
        var nextHeight = HeightRequest > 0 && !_isBrowserFullscreen ? (float)HeightRequest : (float)Math.Round(height);

        if (nextWidth == _measuredCanvasWidth && nextHeight == _measuredCanvasHeight)
            return;

        _measuredCanvasWidth = nextWidth;
        _measuredCanvasHeight = nextHeight;

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnFullscreenChanged(bool isFullscreen)
    {
        if (_isBrowserFullscreen == isFullscreen)
        {
            return;
        }

        _isBrowserFullscreen = isFullscreen;

        if (IsFullscreen != isFullscreen && IsFullscreenChanged.HasDelegate)
        {
            await IsFullscreenChanged.InvokeAsync(isFullscreen);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task SyncFullscreenAsync()
    {
        if (_resizeModule == null || _lastFullscreenRequest == IsFullscreen)
        {
            return;
        }

        try
        {
            var isFullscreen = await _resizeModule.InvokeAsync<bool>("setCanvasFullscreen", _hostElement, IsFullscreen);
            _lastFullscreenRequest = isFullscreen;

            if (_isBrowserFullscreen != isFullscreen)
            {
                _isBrowserFullscreen = isFullscreen;
                await InvokeAsync(StateHasChanged);
            }

            if (IsFullscreen != isFullscreen && IsFullscreenChanged.HasDelegate)
            {
                await IsFullscreenChanged.InvokeAsync(isFullscreen);
            }
        }
        catch
        {
            _lastFullscreenRequest = _isBrowserFullscreen;
        }
    }

    private float CanvasElementWidth => WidthRequest > 0 && !_isBrowserFullscreen
        ? (float)WidthRequest
        : _measuredCanvasWidth > 0 ? _measuredCanvasWidth : AutoCanvasWidth;

    private float CanvasElementHeight => HeightRequest > 0 && !_isBrowserFullscreen
        ? (float)HeightRequest
        : _measuredCanvasHeight > 0 ? _measuredCanvasHeight : AutoCanvasHeight;

    private float AutoCanvasWidth
    {
        get
        {
            if (Content?.WidthRequest > 0)
            {
                return (float)Content.WidthRequest;
            }

            if (Content?.MeasuredSize?.Units.Width > 0)
            {
                return Content.MeasuredSize.Units.Width;
            }

            return 1f;
        }
    }

    private float AutoCanvasHeight
    {
        get
        {
            if (Content?.HeightRequest > 0)
            {
                return (float)Content.HeightRequest;
            }

            if (Content?.MeasuredSize?.Units.Height > 0)
            {
                return Content.MeasuredSize.Units.Height;
            }

            return 1f;
        }
    }

    private string AutoCanvasStyle
    {
        get
        {
            var style = string.Empty;

            if (WidthRequest <= 0 && HorizontalOptions.Alignment != LayoutAlignment.Fill)
            {
                style += $"width: {AutoCanvasWidth.ToString(System.Globalization.CultureInfo.InvariantCulture)}{Units};";
            }

            if (HeightRequest <= 0 && VerticalOptions.Alignment != LayoutAlignment.Fill)
            {
                style += $" height: {AutoCanvasHeight.ToString(System.Globalization.CultureInfo.InvariantCulture)}{Units};";
            }

            return style;
        }
    }

    private string CanvasLayoutClass
    {
        get
        {
            if (WidthRequest > 0 || HeightRequest > 0)
            {
                return "xaml-canvas-fixed";
            }

            if (HorizontalOptions.Alignment == LayoutAlignment.Fill || VerticalOptions.Alignment == LayoutAlignment.Fill)
            {
                return "xaml-canvas-fill";
            }

            return "xaml-canvas-auto";
        }
    }

    public MarkupString CssStyle
    {
        get
        {
            var bg = BackgroundColorCss;
            var ret = $"background: {bg}; {CssLayoutAlignment} {AutoCanvasStyle} {Style}";
            return new MarkupString(ret);
        }
    }

    [Parameter]
    public new RenderingModeType RenderingMode { get; set; }

    [Parameter]
    public new bool CanRenderOffScreen { get; set; }

    // [Parameter]
    // public RenderFragment ChildContent { get; set; }

    [Parameter]
    public bool IsFullscreen { get; set; }

    [Parameter]
    public EventCallback<bool> IsFullscreenChanged { get; set; }

    [Parameter]
    public new GesturesMode Gestures { get; set; } = GesturesMode.Disabled;

    private bool CaptureInput => Gestures != GesturesMode.Disabled;

    private string GestureStyle => CaptureInput ? "touch-action:none; user-select:none;" : string.Empty;

    public async ValueTask DisposeAsync()
    {
        if (_resizeModule != null)
        {
            try { await _resizeModule.InvokeVoidAsync("detachCanvasHost", _hostElement); }
            catch { }
        }

        if (_gestureEffect != null)
        {
            try { await _gestureEffect.DisposeAsync(); }
            catch { }
        }

        if (_resizeModule != null)
        {
            try { await _resizeModule.DisposeAsync(); }
            catch { }
        }

        _resizeCallbackRef?.Dispose();

        OnDisposing();
    }

}


